# ─── Database ──────────────────────────────────────────────────────────────────
# MongoDB connection string — gunakan MongoDB Atlas untuk production
# Format: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
URI=mongodb+srv://username:password@cluster.mongodb.net/trip-app?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Secret key untuk signing JWT access token
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=ganti_dengan_random_string_minimal_32_karakter_yang_sangat_aman

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# URL frontend — dipakai untuk CORS whitelist dan link dalam email
# Development : http://localhost:5173
# Production  : https://your-frontend-domain.vercel.app
CLIENT_URL=http://localhost:5173

# ─── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Akun Gmail pengirim email platform
EMAIL_USER=youremail@gmail.com

# Gmail App Password — BUKAN password akun Google biasa
# Cara: Google Account → Security → 2-Step Verification → App Passwords
# Format: 16 karakter tanpa spasi
EMAIL_PASS=your_gmail_app_password_16_chars

# ─── Admin Credentials ─────────────────────────────────────────────────────────
# Kredensial admin pertama — dibuat via POST /api/auth/admin/register (sekali pakai)
EMAIL_ADMIN=admin@yourdomain.com
EMAIL_ADMIN_PASS=admin_password_minimal_8_karakter

# ─── Midtrans ──────────────────────────────────────────────────────────────────
# Gunakan kredensial SANDBOX untuk development/demo
# Dapatkan di: https://dashboard.sandbox.midtrans.com → Settings → Access Keys
# MIDTRANS_SERVER_KEY dipakai untuk DUA hal:
#   1. Inisialisasi Midtrans SDK (config/midtrans.js)
#   2. Verifikasi signature webhook (middlewares/verifyMidtransWebhook.middleware.js)
#      Formula: SHA512(order_id + status_code + gross_amount + server_key)
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Dapatkan di: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Nama bucket Supabase untuk menyimpan file
SUPABASE_BUCKET=trip-assets

# ─── Gemini API ────────────────────────────────────────────────────────────────
# Dapatkan di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
